# set_location_assignment PIN_D22 -to TU_SENAL_HEX3_DP

# --- HEX 4 ---
# set_location_assignment PIN_F18 -to TU_SENAL_HEX4_A
# set_location_assignment PIN_E20 -to TU_SENAL_HEX4_B
# set_location_assignment PIN_E19 -to TU_SENAL_HEX4_C
# set_location_assignment PIN_J18 -to TU_SENAL_HEX4_D
# set_location_assignment PIN_H19 -to TU_SENAL_HEX4_E
# set_location_assignment PIN_F19 -to TU_SENAL_HEX4_F
# set_location_assignment PIN_F20 -to TU_SENAL_HEX4_G
# set_location_assignment PIN_F17 -to TU_SENAL_HEX4_DP

# --- HEX 5 (El de más a la izquierda) ---
# set_location_assignment PIN_J20 -to TU_SENAL_HEX5_A
# set_location_assignment PIN_K20 -to TU_SENAL_HEX5_B
# set_location_assignment PIN_L18 -to TU_SENAL_HEX5_C
# set_location_assignment PIN_N18 -to TU_SENAL_HEX5_D
# set_location_assignment PIN_M20 -to TU_SENAL_HEX5_E
# set_location_assignment PIN_N19 -to TU_SENAL_HEX5_F
# set_location_assignment PIN_N20 -to TU_SENAL_HEX5_G
# set_location_assignment PIN_L19 -to TU_SENAL_HEX5_DP

# --------------------------------------------------------------------------
# Puerto VGA (Video Graphics Array) de 4 bits por color
# --------------------------------------------------------------------------
# set_location_assignment PIN_N3  -to TU_SENAL_VGA_HSYNC
# set_location_assignment PIN_N1  -to TU_SENAL_VGA_VSYNC
# set_location_assignment PIN_AA1 -to TU_SENAL_VGA_R[0]
# set_location_assignment PIN_V1  -to TU_SENAL_VGA_R[1]
# set_location_assignment PIN_Y2  -to TU_SENAL_VGA_R[2]
# set_location_assignment PIN_Y1  -to TU_SENAL_VGA_R[3]
# set_location_assignment PIN_W1  -to TU_SENAL_VGA_G[0]
# set_location_assignment PIN_T2  -to TU_SENAL_VGA_G[1]
# set_location_assignment PIN_R2  -to TU_SENAL_VGA_G[2]
# set_location_assignment PIN_R1  -to TU_SENAL_VGA_G[3]
# set_location_assignment PIN_P1  -to TU_SENAL_VGA_B[0]
# set_location_assignment PIN_T1  -to TU_SENAL_VGA_B[1]
# set_location_assignment PIN_P4  -to TU_SENAL_VGA_B[2]
# set_location_assignment PIN_N2  -to TU_SENAL_VGA_B[3]

# ==============================================================================
# ESTÁNDAR DE VOLTAJE (Crucial para la DE10-Lite)
# ==============================================================================
# set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to *


# ==============================================================================
# ARCHIVOS A COMPILAR DEL PROYECTO (AGREGAR NUEVOS) 
# ==============================================================================

set_global_assignment -name VHDL_FILE src/digitalFIR.vhd
