# set_location_assignment PIN_A18 -to TU_SENAL_HEX1_F
# set_location_assignment PIN_B17 -to TU_SENAL_HEX1_G
# set_location_assignment PIN_A16 -to TU_SENAL_HEX1_DP

# --- HEX 2 ---
# set_location_assignment PIN_B20 -to TU_SENAL_HEX2_A
# set_location_assignment PIN_A20 -to TU_SENAL_HEX2_B
# set_location_assignment PIN_B19 -to TU_SENAL_HEX2_C
# set_location_assignment PIN_A21 -to TU_SENAL_HEX2_D
# set_location_assignment PIN_B21 -to TU_SENAL_HEX2_E
# set_location_assignment PIN_C22 -to TU_SENAL_HEX2_F
# set_location_assignment PIN_B22 -to TU_SENAL_HEX2_G
# set_location_assignment PIN_A19 -to TU_SENAL_HEX2_DP

# --- HEX 3 ---
# set_location_assignment PIN_F21 -to TU_SENAL_HEX3_A
# set_location_assignment PIN_E22 -to TU_SENAL_HEX3_B
# set_location_assignment PIN_E21 -to TU_SENAL_HEX3_C
